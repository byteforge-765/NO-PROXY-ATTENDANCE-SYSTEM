{
  "name": "icms-backend",
  "version": "2.0.0",
  "description": "Integrated Campus Management System - Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node database/seed.js",
    "db:setup": "psql -U $POSTGRES_USER -d $POSTGRES_DB -f database/schema.sql && npm run seed",
    "tg:setup": "node database/tigergraph_setup.js",
    "tg:sync-all": "node database/tigergraph_sync_all.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "mongoose": "^8.0.3",
    "redis": "^4.6.10",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "morgan": "^1.10.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "twilio": "^4.20.0",
    "axios": "^1.6.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}