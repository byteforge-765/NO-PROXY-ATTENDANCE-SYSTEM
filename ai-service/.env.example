# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=icms
POSTGRES_USER=icms_user
POSTGRES_PASSWORD=your_password_here

# ── Face Recognition ────────────────────────────────────
# 0.45 works well for InsightFace buffalo_l
# Raise to 0.50 for stricter, lower to 0.40 for lenient
FACE_MATCH_THRESHOLD=0.45

# ── Server ──────────────────────────────────────────────
PORT=8001
ENVIRONMENT=development
